# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Used by the backend to send 6-digit Telegram account-linking codes.
# Leave SMTP_HOST empty to disable real emails (codes are printed to logs only).
#
# Gmail (recommended):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to Google Account → Security → App passwords → generate one
#   3. Use port 465 (implicit TLS / SMTPS)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=you@gmail.com

# ── Optional overrides ────────────────────────────────────────────────────────
# BOT_LINK_SECRET=change-me          # shared secret between backend and tgbot
# SENTRY_DSN_BACKEND=https://...     # GlitchTip DSN for backend error tracking
# SENTRY_DSN_TGBOT=https://...       # GlitchTip DSN for tgbot error tracking
