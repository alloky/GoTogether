# ── Alert Telegram Bot ───────────────────────────────────────────────────────
# Create a new bot via @BotFather — must be DIFFERENT from the GoTogether bot
# Then add it to your alert group and get the group chat ID

ALERT_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Group chat ID — negative number for groups, get it via:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  (send a message to the group first)
ALERT_CHAT_ID=-1001234567890

# Optional: shared secret for webhook validation
SENTRY_SECRET=

# ── GlitchTip ────────────────────────────────────────────────────────────────
# Random string for Django session signing. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
GLITCHTIP_SECRET_KEY=change-me-to-a-random-string

# ── Alertmanager also needs these via environment substitution ───────────────
# alertmanager.yml references ${ALERT_BOT_TOKEN} and ${ALERT_CHAT_ID}
# Alertmanager supports env var substitution natively
